{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Cortex capabilities — deny by default, explicit grants only",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    {
      "identifier": "core:event:allow-emit",
      "allow": [{ "event": "pty:*" }, { "event": "session:*" }, { "event": "cortex:*" }]
    },
    {
      "identifier": "core:event:allow-listen",
      "allow": [{ "event": "pty:*" }, { "event": "session:*" }, { "event": "cortex:*" }]
    },
    "global-shortcut:default"
  ]
}
